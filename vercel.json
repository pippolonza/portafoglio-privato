{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.js"
    }
  ],
  "functions": {
    "index.js": {
      "includeFiles": [
        "index.html",
        "client.js",
        "styles.css",
        "icon.svg",
        "manifest.webmanifest",
        "sw.js"
      ]
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
